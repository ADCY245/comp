# ====================================
# Product Calculator Environment Variables
# ====================================

# Database Configuration
# ===================
# MongoDB Connection String
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-address>/<database>?retryWrites=true&w=majority
# Set to True to use MongoDB, False to use JSON files
USE_MONGO=True

# JWT Configuration
# ================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Email Configuration
# =================
# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false  # true for port 465, false for other ports
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password-or-app-password

# Email Sender Information
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME="Product Calculator"

# Application Settings
# ==================
FLASK_APP=run.py
FLASK_ENV=development  # Set to 'production' in production
PORT=5000
SECRET_KEY=your-secret-key-here

# Security
# =======
# Set to 'True' in production
SECURE_COOKIES=False
WTF_CSRF_ENABLED=True
WTF_CSRF_SECRET_KEY=your-csrf-secret-key-here

# Logging
# ======
LOG_LEVEL=INFO

# Admin User (for first-time setup)
# ===============================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Note: Copy this file to .env and fill in your actual values
# Never commit .env to version control
